import { Button, ScrollView, ProgressIndicator, LineEdit, ListView } from "std-widgets.slint";

// ── Data model ────────────────────────────────────────────────────────────────

export struct TorrentItem {
    id: int,
    name: string,
    status-label: string,
    progress: float,
    down-speed: string,
    up-speed: string,
    is-paused: bool,
    is-error: bool,
    is-checking: bool,
    download-dir: string,
    error-string: string,
}

export struct SessionStats {
    down-speed: string,
    up-speed: string,
    downloaded: string,
    uploaded: string,
    ratio: string,
    active: int,
    dht: int,
    peers: int,
}

export struct DiskItem {
    label: string,
    kind: string,       // "disk", "raid", "lvm", "btrfs"
    mountpoints: string, // через ", "
    torrent-count: int,
}

// ── Confirm dialog ────────────────────────────────────────────────────────────

component ConfirmDialog inherits Rectangle {
    in property <string> message;
    in property <string> torrent-name;
    in property <bool>   show-warning;
    in property <bool>   visible-dialog;
    in property <string> tr-cancel;
    in property <string> tr-confirm;
    in property <string> tr-delete-warning;
    in property <string> tr-irreversible;
    callback confirmed();
    callback cancelled();

    visible: visible-dialog;
    z: 100;
    background: #00000099;

    Rectangle {
        width: 480px; height: show-warning ? 240px : 180px;
        background: #1e2430;
        border-radius: 10px;
        border-width: 1px; border-color: #3a4560;

        VerticalLayout {
            padding: 24px; spacing: 16px;
            
            // Torrent name
            if torrent-name != "": Text {
                text: "🗂 " + torrent-name;
                color: #70a8d8; font-size: 13px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            
            // Main message
            Text {
                text: message; color: #dce4f5; font-size: 14px;
                wrap: word-wrap; horizontal-alignment: center;
            }
            
            // Warning for file deletion
            if show-warning: VerticalLayout {
                spacing: 6px;
                Text {
                    text: tr-delete-warning;
                    color: #e08080; font-size: 12px;
                    horizontal-alignment: center;
                }
                Text {
                    text: tr-irreversible;
                    color: #a06060; font-size: 11px;
                    horizontal-alignment: center;
                }
            }
            
            HorizontalLayout {
                spacing: 14px; alignment: center;
                Button { text: tr-cancel;  clicked => { cancelled(); } }
                Button { text: tr-confirm; clicked => { confirmed(); } }
            }
        }
    }
}

// ── Close dialog: свернуть в трей или закрыть ─────────────────────────────────

component CloseDialog inherits Rectangle {
    in property <bool> visible-dialog;
    callback minimize-to-tray();
    callback quit-app();
    callback cancelled();

    visible: visible-dialog;
    z: 100;
    background: #00000099;

    Rectangle {
        width: 380px; height: 190px;
        background: #1e2430;
        border-radius: 10px;
        border-width: 1px; border-color: #3a4560;

        VerticalLayout {
            padding: 28px; spacing: 18px;

            Text {
                text: "What would you like to do?";
                color: #dce4f5; font-size: 14px;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                spacing: 10px; alignment: center;
                Button {
                    text: "⬇ Minimize to tray";
                    clicked => { minimize-to-tray(); }
                }
                Button {
                    text: "✕ Quit";
                    clicked => { quit-app(); }
                }
            }

            HorizontalLayout {
                alignment: center;
                Button {
                    text: "Cancel";
                    clicked => { cancelled(); }
                }
            }
        }
    }
}

// ── Add torrent dialog ────────────────────────────────────────────────────────

component AddTorrentDialog inherits Rectangle {
    in property <bool> visible-dialog;
    callback submitted-url(string);
    callback pick-file();
    callback cancelled();

    visible: visible-dialog;
    z: 100;
    background: #00000099;

    property <string> input-text: "";

    Rectangle {
        width: 540px; height: 200px;
        background: #1e2430;
        border-radius: 10px;
        border-width: 1px; border-color: #3a4560;

        VerticalLayout {
            padding: 24px; spacing: 14px;
            Text {
                text: "Add torrent";
                color: #dce4f5; font-size: 15px; font-weight: 600;
                horizontal-alignment: center;
            }
            HorizontalLayout {
                spacing: 8px;
                LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "magnet:?xt=urn:btih:…  or  https://…";
                    text <=> input-text;
                    accepted(t) => {
                        if (t != "") { submitted-url(t); input-text = ""; }
                    }
                }
                Button {
                    text: "Add URL";
                    clicked => {
                        if (input-text != "") { submitted-url(input-text); input-text = ""; }
                    }
                }
            }
            HorizontalLayout {
                spacing: 12px; alignment: center;
                Button { text: "📂 Browse .torrent…"; clicked => { pick-file(); } }
                Button { text: "Cancel"; clicked => { input-text = ""; cancelled(); } }
            }
        }
    }
}

// ── Create torrent dialog ─────────────────────────────────────────────────────

component CreateTorrentDialog inherits Rectangle {
    in property <bool> visible-dialog;
    in-out property <string> path-text: "";
    callback submitted(string, string);
    callback pick-path();
    callback cancelled();

    visible: visible-dialog;
    z: 100;
    background: #00000099;

    property <string> trackers-text: "";

    Rectangle {
        width: 580px; height: 260px;
        background: #1e2430;
        border-radius: 10px;
        border-width: 1px; border-color: #3a4560;

        VerticalLayout {
            padding: 24px; spacing: 14px;

            Text {
                text: "Create torrent";
                color: #dce4f5; font-size: 15px; font-weight: 600;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                spacing: 8px;
                LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "/path/to/folder or file";
                    text <=> path-text;
                }
                Button { text: "📂 Browse…"; clicked => { pick-path(); } }
            }

            LineEdit {
                placeholder-text: "Trackers (one URL per line, optional)";
                text <=> trackers-text;
            }

            HorizontalLayout {
                spacing: 12px; alignment: center;
                Button {
                    text: "✚ Create";
                    clicked => {
                        if (path-text != "") {
                            submitted(path-text, trackers-text);
                            path-text = ""; trackers-text = "";
                        }
                    }
                }
                Button {
                    text: "Cancel";
                    clicked => { path-text = ""; trackers-text = ""; cancelled(); }
                }
            }
        }
    }
}

// ── Magnet dialog ─────────────────────────────────────────────────────────────

// ── Set Location Dialog ───────────────────────────────────────────────────────

component SetLocationDialog inherits Rectangle {
    in property <bool>   visible-dialog;
    in property <string> torrent-name;
    in-out property <string> path: "";
    in-out property <bool>   do-move: true;
    callback pick-folder();          // открыть XDG выбор папки
    callback confirmed(string, bool); // path, do-move
    callback cancelled();

    visible: visible-dialog;
    z: 200;
    background: #00000099;

    Rectangle {
        width: 520px; height: 230px;
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        background: #1e2430;
        border-radius: 12px;
        border-width: 1px; border-color: #3a4560;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000088;

        VerticalLayout {
            padding: 22px; spacing: 16px;

            // ── Header ──────────────────────────────────────────────────────
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "📍 Указать расположение";
                    color: #dce4f5; font-size: 15px; font-weight: 700;
                    horizontal-alignment: center;
                }
                if torrent-name != "": Text {
                    text: torrent-name;
                    color: #6a8ab8; font-size: 12px;
                    horizontal-alignment: center;
                    overflow: elide;
                }
            }

            // ── Path input row ───────────────────────────────────────────────
            HorizontalLayout {
                spacing: 8px;
                LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "/home/user/Downloads";
                    text <=> path;
                }
                Rectangle {
                    width: 36px; height: 36px;
                    background: folder-btn.has-hover ? #2e4a70 : #253450;
                    border-radius: 7px;
                    border-width: 1px; border-color: #3a5070;
                    Text {
                        text: "📁";
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    folder-btn := TouchArea {
                        clicked => { pick-folder(); }
                    }
                }
            }

            // ── Toggle: переместить файлы ────────────────────────────────────
            HorizontalLayout {
                spacing: 10px; alignment: start;
                // Toggle track
                Rectangle {
                    width: 40px; height: 22px;
                    border-radius: 11px;
                    background: do-move ? #4a7cf7 : #2a3448;
                    animate background { duration: 150ms; }
                    // Thumb
                    Rectangle {
                        width: 16px; height: 16px;
                        border-radius: 8px;
                        background: #ffffff;
                        x: do-move ? 21px : 3px;
                        y: 3px;
                        animate x { duration: 150ms; }
                    }
                    TouchArea { clicked => { do-move = !do-move; } }
                }
                Text {
                    text: do-move ? "Переместить файлы" : "Только обновить путь";
                    color: #c0d0e8; font-size: 13px;
                    vertical-alignment: center;
                }
            }

            // ── Buttons ──────────────────────────────────────────────────────
            HorizontalLayout {
                spacing: 10px; alignment: center;
                Button {
                    text: "Отмена";
                    clicked => { cancelled(); }
                }
                Button {
                    text: do-move ? "Переместить" : "Применить";
                    primary: true;
                    clicked => {
                        if (path != "") { confirmed(path, do-move); }
                    }
                }
            }
        }
    }
}

component MagnetDialog inherits Rectangle {
    in property <bool> visible-dialog;
    in-out property <string> magnet-uri: "";
    callback submitted(string);
    callback cancelled();

    visible: visible-dialog;
    z: 100;
    background: #00000099;

    Rectangle {
        width: 500px; height: 180px;
        background: #1e2430;
        border-radius: 10px;
        border-width: 1px; border-color: #3a4560;

        VerticalLayout {
            padding: 24px; spacing: 14px;

            Text {
                text: "Add Magnet Link";
                color: #dce4f5; font-size: 15px; font-weight: 600;
                horizontal-alignment: center;
            }

            LineEdit {
                horizontal-stretch: 1;
                placeholder-text: "magnet:?xt=urn:btih:...";
                text <=> magnet-uri;
            }

            HorizontalLayout {
                spacing: 12px; alignment: center;
                Button {
                    text: "OK";
                    clicked => {
                        if (magnet-uri != "") {
                            submitted(magnet-uri);
                            magnet-uri = "";
                        }
                    }
                }
                Button {
                    text: "Cancel";
                    clicked => { magnet-uri = ""; cancelled(); }
                }
            }
        }
    }
}

// ── Settings dialog ───────────────────────────────────────────────────────────

component SettingsDialog inherits Rectangle {
    in property <bool> visible-dialog;
    in-out property <string> selected-language: "en";
    callback language-changed(string);
    callback cancelled();

    visible: visible-dialog;
    z: 100;
    background: #00000099;

    Rectangle {
        width: 380px; height: 320px;
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        background: #1e2430;
        border-radius: 12px;
        border-width: 1px; border-color: #3a4560;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000088;

        VerticalLayout {
            padding: 22px; spacing: 14px;

            // ── Header ──────────────────────────────────────────────────────
            VerticalLayout {
                spacing: 5px;
                Text {
                    text: "🌐 Язык интерфейса";
                    color: #dce4f5; font-size: 15px; font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: "⚠ Требуется перезапуск";
                    color: #c08030; font-size: 11px;
                    horizontal-alignment: center;
                }
            }

            // ── Language list ────────────────────────────────────────────────
            for lang-item in [
                {code: "en", label: "🇬🇧  English"},
                {code: "de", label: "🇩🇪  Deutsch"},
                {code: "ru", label: "🇷🇺  Русский"},
                {code: "zh", label: "🇨🇳  中文"},
                {code: "es", label: "🇪🇸  Español"},
            ]: Rectangle {
                height: 34px;
                border-radius: 7px;
                border-width: 1px;
                background: selected-language == lang-item.code ? #1e3a5a
                          : (lang-ta.has-hover ? #232d40 : #181f2e);
                border-color: selected-language == lang-item.code ? #4a8aba : transparent;
                animate background { duration: 120ms; }

                HorizontalLayout {
                    padding-left: 14px; padding-right: 14px;
                    spacing: 0px;
                    Text {
                        text: lang-item.label;
                        color: selected-language == lang-item.code ? #a8d4f8 : #8090b0;
                        font-size: 13px;
                        vertical-alignment: center;
                        animate color { duration: 120ms; }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    if selected-language == lang-item.code: Text {
                        text: "✓";
                        color: #4a8aba; font-size: 13px;
                        vertical-alignment: center;
                    }
                }
                lang-ta := TouchArea {
                    clicked => { selected-language = lang-item.code; language-changed(lang-item.code); }
                }
            }

            // ── Close button ─────────────────────────────────────────────────
            Rectangle {
                height: 34px;
                border-radius: 7px;
                border-width: 1px;
                background: close-ta.has-hover ? #2a3a50 : #1e2a3a;
                border-color: #3a4a60;
                animate background { duration: 120ms; }
                Text {
                    text: "Закрыть";
                    color: #8090b0;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                close-ta := TouchArea { clicked => { cancelled(); } }
            }
        }
    }
}

// ── Torrent row ───────────────────────────────────────────────────────────────
component TorrentRow inherits Rectangle {
    in property <TorrentItem> item;
    in property <bool>        is-even;
    in property <bool>        is-selected;
    in property <int>         row-index;
    in property <length>      col-name-w:   290px;
    in property <length>      col-status-w: 100px;
    in property <length>      col-done-w:    54px;
    in property <length>      col-down-w:    80px;
    callback request-context-menu(int, string, string, bool, int, int, int); // id, name, dir, paused, x, y, index

    height: 50px;
    background: is-selected ? #2a3a50 : (is-even ? #161c27 : #1a2233);
    states [ hovered when ta.has-hover && !is-selected : { background: #1e2840; } ]
    animate background { duration: 60ms; }

    ta := TouchArea {
        pointer-event(event) => {
            if (event.kind == PointerEventKind.up && event.button == PointerEventButton.right) {
                request-context-menu(
                    item.id,
                    item.name,
                    item.download-dir,
                    item.is-paused,
                    (self.absolute-position.x + self.mouse-x) / 1px,
                    (self.absolute-position.y + self.mouse-y) / 1px,
                    row-index
                );
            }
        }
    }

    HorizontalLayout {
        padding-left: 12px; padding-right: 6px;
        spacing: 0px; alignment: stretch;

        // Имя + прогресс + ошибка
        VerticalLayout {
            width: col-name-w; alignment: center; spacing: 3px;
            Text {
                text: item.name; color: #d0d8ec;
                font-size: 13px; overflow: elide;
            }
            if item.is-error && item.error-string != "" : Text {
                text: item.error-string;
                color: #c06050; font-size: 10px; overflow: elide;
            }
            if !item.is-error : ProgressIndicator { progress: item.progress; height: 5px; }
        }

        Rectangle { width: 9px; }

        Text {
            width: col-status-w;
            text: item.is-checking
                ? (item.status-label + " " + Math.round(item.progress * 100) + "%")
                : item.status-label;
            color: item.is-error   ? #c04040
                 : item.is-paused  ? #556070
                 : item.is-checking? #a07830
                 : #38b865;
            font-size: 12px; vertical-alignment: center;
        }

        Rectangle { width: 9px; }

        Text {
            width: col-done-w;
            text: item.is-checking ? "" : Math.round(item.progress * 100) + "%";
            color: #687888; font-size: 12px;
            horizontal-alignment: center; vertical-alignment: center;
        }

        Rectangle { width: 9px; }

        Text {
            width: col-down-w; text: "↓ " + item.down-speed;
            color: #4a9ed8; font-size: 12px; vertical-alignment: center;
        }

        Rectangle { width: 9px; }

        Text {
            horizontal-stretch: 1; text: "↑ " + item.up-speed;
            color: #c87e28; font-size: 12px; vertical-alignment: center;
        }
    }
}

// ── Статистика сессии (правая часть статусбара) ───────────────────────────────

component StatsBar inherits HorizontalLayout {
    in property <SessionStats> stats;
    spacing: 16px;
    alignment: end;

    // Активные раздачи
    Text {
        text: stats.active + " active";
        color: #406858; font-size: 11px; vertical-alignment: center;
    }
    Rectangle { width: 1px; height: 12px; background: #1e2a40; }
    // Скорости
    Text {
        text: "↓ " + stats.down-speed;
        color: #2a6898; font-size: 11px; vertical-alignment: center;
    }
    Text {
        text: "↑ " + stats.up-speed;
        color: #885818; font-size: 11px; vertical-alignment: center;
    }
    Rectangle { width: 1px; height: 12px; background: #1e2a40; }
    // Объёмы
    Text {
        text: "⬇ " + stats.downloaded;
        color: #385868; font-size: 11px; vertical-alignment: center;
    }
    Text {
        text: "⬆ " + stats.uploaded;
        color: #785030; font-size: 11px; vertical-alignment: center;
    }
    Rectangle { width: 1px; height: 12px; background: #1e2a40; }
    // Соотношение
    Text {
        text: "R " + stats.ratio;
        color: #506838; font-size: 11px; vertical-alignment: center;
    }
    Rectangle { width: 8px; }
}

// ── Main window ───────────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "Transmission Remote";
    icon: @image-url("app-icon.png");
    background: #111722;
    min-width: 740px; min-height: 460px;
    preferred-width: 1060px; preferred-height: 700px;

    in property <[TorrentItem]> torrents;
    in property <SessionStats>  stats;
    in property <string>  status-bar-text: "Starting…";
    in property <bool>    connected: false;
    in property <[DiskItem]> disk-groups;
    in-out property <int> selected-disk: -1; // -1 = All

    // Счётчики для левой панели
    in-out property <int> count-all: 0;
    in-out property <int> count-downloading: 0;
    in-out property <int> count-seeding: 0;
    in-out property <int> count-completed: 0;
    in-out property <int> count-stopped: 0;
    in-out property <int> count-active: 0;
    in-out property <int> count-error: 0;
    in-out property <string> active-filter: "all";

    // Column widths (resizable via header drag)
    in-out property <length> col-name-w:   290px;
    in-out property <length> col-status-w: 100px;
    in-out property <length> col-done-w:    54px;
    in-out property <length> col-down-w:    80px;

    // Sort: "" | "done" | "down" | "up",  asc=true means smallest first
    in-out property <string> sort-col: "";
    in-out property <bool>   sort-asc: false;
    callback sort-changed(string, bool); // col, asc

    // RPC connection
    in-out property <string>   rpc-url: "localhost";
    in-out property <[string]> rpc-candidates: [];
    in-out property <bool>     rpc-popup-visible: false;
    callback switch-rpc(string);

    // Confirm dialog
    in-out property <bool>   dialog-visible: false;
    in-out property <string> dialog-message: "";
    in-out property <int>    pending-id: -1;
    in-out property <bool>   pending-delete-files: false;
    in-out property <bool>   pending-is-delete: false;
    in-out property <string> pending-torrent-name: "";

    // Close dialog
    in-out property <bool>   close-dialog-visible: false;

    // Переводы диалога удаления
    in-out property <string> tr-dlg-remove-title: "Remove torrent?";
    in-out property <string> tr-dlg-remove-subtitle: "(files will be kept)";
    in-out property <string> tr-dlg-delete-title: "Delete torrent AND files?";
    in-out property <string> tr-dlg-delete-warning: "All files will be permanently deleted from disk.";
    in-out property <string> tr-dlg-irreversible: "This action cannot be undone.";
    in-out property <string> tr-dlg-confirm: "Confirm";
    in-out property <string> tr-dlg-cancel: "Cancel";

    // Add dialog
    in-out property <bool>   add-dialog-visible: false;

    // Create torrent dialog
    in-out property <bool>   create-dialog-visible: false;
    in-out property <string> pending-create-path: "";

    // Magnet dialog
    in-out property <bool>   magnet-dialog-visible: false;
    in-out property <string> magnet-uri: "";

    // Settings dialog
    in-out property <bool>   settings-dialog-visible: false;
    in-out property <string> selected-language: "en";

    // Context menu
    in-out property <bool>   context-menu-visible: false;
    in-out property <int>    context-menu-target-id: -1;
    in-out property <int>    context-menu-target-index: -1;
    in-out property <string> context-menu-torrent-name: "";
    in-out property <string> context-menu-torrent-dir: "";
    in-out property <bool>   context-menu-target-paused: false;
    in-out property <int>    context-menu-x: 0;
    in-out property <int>    context-menu-y: 0;
    in-out property <int>    selected-index: -1;

    // Set location dialog
    in-out property <bool>   set-location-dialog-visible: false;
    in-out property <int>    set-location-torrent-id: -1;
    in-out property <string> set-location-torrent-name: "";
    in-out property <string> set-location-path: "";
    in-out property <bool>   set-location-do-move: true; // радиокнопка: true=переместить, false=только путь

    // Поиск
    in-out property <string> search-text: "";

    // Переводы UI
    in property <string> tr-toolbar-open: "Open";
    in property <string> tr-toolbar-magnet: "Magnet";
    in property <string> tr-toolbar-create: "Create";
    in property <string> tr-toolbar-rehash: "Rehash";
    in property <string> tr-sidebar-status: "Status";
    in property <string> tr-sidebar-all: "All";
    in property <string> tr-sidebar-downloading: "Downloading";
    in property <string> tr-sidebar-seeding: "Seeding";
    in property <string> tr-sidebar-completed: "Completed";
    in property <string> tr-sidebar-stopped: "Stopped";
    in property <string> tr-sidebar-active: "Active";
    in property <string> tr-sidebar-inactive: "Inactive";
    in property <string> tr-sidebar-checking: "Checking";
    in property <string> tr-sidebar-error: "Error";
    in property <string> tr-sidebar-disks: "Disks";
    in property <string> tr-column-name: "Name";
    in property <string> tr-column-status: "Status";
    in property <string> tr-column-done: "Done";
    in property <string> tr-column-down: "Down";
    in property <string> tr-column-up: "Up";
    in property <string> tr-menu-start: "Start";
    in property <string> tr-menu-pause: "Pause";
    in property <string> tr-menu-recheck: "Recheck";
    in property <string> tr-menu-open-folder: "Open Folder";
    in property <string> tr-menu-set-location: "Set Location";
    in property <string> tr-menu-remove: "Remove Torrent";
    in property <string> tr-menu-delete: "Delete Torrent + Files";

    in property <string> tr-statusbar-dht:  "DHT";
    in property <string> tr-statusbar-conn: "conn";

    callback search-changed(string);
    callback rehash-errors();
    callback filter-clicked(string);
    callback magnet-submitted(string);
    callback language-changed(string);

    // Callbacks
    callback start-torrent(int);
    callback stop-torrent(int);
    callback start-all();
    callback stop-all();
    callback remove-torrent(int, bool);
    callback recheck-torrent(int);
    callback open-folder(string);
    callback request-set-location(int, string, string); // legacy callback, kept for main.rs wiring
    callback set-location(int, string, bool);
    callback set-location-cmd(int, string, bool); // internal: sends to backend
    callback set-location-xdg-dialog(int, string, string, bool); // id, name, current_dir, do_move → сразу действие
    callback pick-context-menu-set-location(int, string, string); // from context menu → open dialog
    callback get-last-location() -> string; // returns last used download dir
    callback click-outside(); // close context menu
    callback add-torrent-url(string);
    callback pick-torrent-file();
    callback create-torrent(string, string);  // path, trackers
    callback pick-create-path();
    callback do-minimize-tray();
    callback do-quit();
    callback stop-disk-torrents(int);   // пауза всех торрентов на диске idx
    callback start-disk-torrents(int);  // возобновить все торренты на диске idx

    VerticalLayout {
        spacing: 0px;

        // ── Toolbar ───────────────────────────────────────────────────────────
        Rectangle {
            height: 42px; background: #0d1420;

            HorizontalLayout {
                padding-left: 8px; padding-right: 8px;
                spacing: 2px; alignment: start;

                // Кнопки влево - стиль как в мокапе
                Rectangle {
                    width: 90px;
                    height: 28px;
                    y: 7px;
                    background: btn-open.has-hover ? #21253a : transparent;
                    border-radius: 5px;
                    border-width: 1px;
                    border-color: btn-open.has-hover ? #343858 : transparent;
                    animate background { duration: 80ms; }
                    animate border-color { duration: 80ms; }
                    btn-open := TouchArea { clicked => { pick-torrent-file(); } }
                    Text {
                        text: "➕ " + tr-toolbar-open;
                        color: #8f97b8;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 80px;
                    height: 28px;
                    y: 7px;
                    background: btn-magnet.has-hover ? #21253a : transparent;
                    border-radius: 5px;
                    border-width: 1px;
                    border-color: btn-magnet.has-hover ? #343858 : transparent;
                    animate background { duration: 80ms; }
                    animate border-color { duration: 80ms; }
                    btn-magnet := TouchArea { clicked => { magnet-dialog-visible = true; } }
                    Text {
                        text: "🧲 " + tr-toolbar-magnet;
                        color: #8f97b8;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 80px;
                    height: 28px;
                    y: 7px;
                    background: btn-create.has-hover ? #21253a : transparent;
                    border-radius: 5px;
                    border-width: 1px;
                    border-color: btn-create.has-hover ? #343858 : transparent;
                    animate background { duration: 80ms; }
                    animate border-color { duration: 80ms; }
                    btn-create := TouchArea { clicked => { create-dialog-visible = true; } }
                    Text {
                        text: "📀 " + tr-toolbar-create;
                        color: #8f97b8;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 80px;
                    height: 28px;
                    y: 7px;
                    background: count-error > 0
                        ? (btn-rehash.has-hover ? #2a1e10 : #1a1208)
                        : (btn-rehash.has-hover ? #21253a : transparent);
                    border-radius: 5px;
                    border-width: 1px;
                    border-color: count-error > 0
                        ? (btn-rehash.has-hover ? #c87030 : #6a3808)
                        : (btn-rehash.has-hover ? #343858 : transparent);
                    animate background { duration: 80ms; }
                    animate border-color { duration: 80ms; }
                    btn-rehash := TouchArea {
                        clicked => { if (count-error > 0) { rehash-errors(); } }
                    }
                    Text {
                        text: "⟳ " + tr-toolbar-rehash;
                        color: count-error > 0
                            ? (btn-rehash.has-hover ? #e8a050 : #b06820)
                            : #3a4258;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 80ms; }
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // Поиск — по центру
                Rectangle {
                    width: 400px;
                    height: 28px;
                    y: 7px;
                    background: #0a1018;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #1e2e42;

                    HorizontalLayout {
                        padding-left: 10px; padding-right: 8px; spacing: 6px;

                        Text {
                            text: "🔍";
                            font-size: 13px;
                            color: #506070;
                            vertical-alignment: center;
                        }

                        search-input := TextInput {
                            horizontal-stretch: 1;
                            font-size: 13px;
                            color: #c8d8ec;
                            selection-background-color: #1a3a5c;
                            selection-foreground-color: #dce8ff;
                            vertical-alignment: center;
                            text <=> search-text;
                            edited => { search-changed(self.text); }
                        }

                        if search-text != "" : Rectangle {
                            width: 20px; height: 20px;
                            border-radius: 10px;
                            background: clear-ta.has-hover ? #2a3a50 : transparent;
                            y: (parent.height - self.height) / 2;
                            clear-ta := TouchArea {
                                clicked => { search-text = ""; search-changed(""); }
                            }
                            Text {
                                text: "✕";
                                font-size: 11px;
                                color: #8f97b8;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // Кнопка настроек — правый угол с текущим языком
                Rectangle {
                    width: 50px;
                    height: 28px;
                    y: 7px;
                    background: btn-settings.has-hover ? #21253a : transparent;
                    border-radius: 5px;
                    border-width: 1px;
                    border-color: btn-settings.has-hover ? #343858 : transparent;
                    animate background { duration: 80ms; }
                    animate border-color { duration: 80ms; }
                    btn-settings := TouchArea { clicked => { settings-dialog-visible = true; } }
                    Text {
                        text: selected-language == "en" ? "EN" : selected-language == "de" ? "DE" : selected-language == "ru" ? "RU" : selected-language == "zh" ? "ZH" : selected-language == "es" ? "ES" : "EN";
                        color: #90c8f0;
                        font-size: 12px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px; x: 0;
                width: 100%; height: 1px; background: #202e48;
            }
        }

        // ── Content: sidebar + torrent list ──────────────────────────────────
        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            // ── LEFT PANEL ────────────────────────────────────────────────────
            Rectangle {
                width: 200px;
                background: #0d1420;
                border-width: 1px;
                border-color: #202e48;

                ScrollView {
                    VerticalLayout {
                        padding: 4px;
                        spacing: 2px;

                        // Заголовок СОСТОЯНИЕ
                        Rectangle {
                            height: 24px;
                            width: 100%;
                            Text {
                                text: tr-sidebar-status;
                                color: #506070;
                                font-size: 10px;
                                font-weight: 600;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                        }

                        // Все
                        Rectangle {
                            height: 26px;
                            background: active-filter == "all" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "all"; filter-clicked("all"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #38c058;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-all;
                                color: active-filter == "all" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "all" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-all + "";
                                    color: active-filter == "all" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Активные
                        Rectangle {
                            height: 26px;
                            background: active-filter == "active" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "active"; filter-clicked("active"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #4a7cf7;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-active;
                                color: active-filter == "active" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "active" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-active + "";
                                    color: active-filter == "active" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Загружаются
                        Rectangle {
                            height: 26px;
                            background: active-filter == "downloading" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "downloading"; filter-clicked("downloading"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #4a7cf7;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-downloading;
                                color: active-filter == "downloading" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "downloading" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-downloading + "";
                                    color: active-filter == "downloading" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Раздаются
                        Rectangle {
                            height: 26px;
                            background: active-filter == "seeding" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "seeding"; filter-clicked("seeding"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #3db87a;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-seeding;
                                color: active-filter == "seeding" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "seeding" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-seeding + "";
                                    color: active-filter == "seeding" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Остановлены
                        Rectangle {
                            height: 26px;
                            background: active-filter == "stopped" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "stopped"; filter-clicked("stopped"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #8f97b8;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-stopped;
                                color: active-filter == "stopped" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "stopped" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-stopped + "";
                                    color: active-filter == "stopped" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Ошибка
                        Rectangle {
                            height: 26px;
                            background: active-filter == "error" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "error"; filter-clicked("error"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #e05555;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-error;
                                color: active-filter == "error" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "error" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-error + "";
                                    color: active-filter == "error" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Завершены
                        Rectangle {
                            height: 26px;
                            background: active-filter == "completed" ? #21253a : transparent;
                            border-radius: 4px;
                            TouchArea { clicked => { active-filter = "completed"; filter-clicked("completed"); } }
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: #3db87a;
                                x: 8px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: tr-sidebar-completed;
                                color: active-filter == "completed" ? #e4e7f2 : #8f97b8;
                                font-size: 12px;
                                x: 24px;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 50px; height: 20px;
                                background: active-filter == "completed" ? #282d42 : #1a1d27;
                                border-radius: 3px;
                                x: parent.width - 58px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: count-completed + "";
                                    color: active-filter == "completed" ? #90c8f0 : #4e556e;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Разделитель
                        Rectangle {
                            height: 1px;
                            background: #252840;
                            width: 192px;
                            x: 4px;
                        }
                    }
                }
            }

            // ── Main list area ────────────────────────────────────────────────
            VerticalLayout {
                spacing: 0px;
                horizontal-stretch: 1;

                // ── Column headers ────────────────────────────────────────────────────
        Rectangle {
            height: 24px; background: #0b1420;
            border-width: 1px; border-color: #1a2535;
            // Доступная ширина для всех колонок = ширина header минус отступы (18px) и 4 разделителя (36px)
            property <length> avail: self.width - 54px;

            HorizontalLayout {
                padding-left: 12px; padding-right: 6px; spacing: 0px;

                // Name
                Text {
                    width: col-name-w;
                    text: tr-column-name;
                    color: #4a5870; font-size: 11px;
                    vertical-alignment: center;
                }

                // Разделитель Name|Status
                Rectangle {
                    width: 9px; height: parent.height;
                    property <length> drag-start-x; property <length> drag-start-w;
                    Rectangle { width: 1px; height: parent.height; x: 4px; background: sep-ns.has-hover ? #3a5070 : #1e2a3a; }
                    sep-ns := TouchArea {
                        mouse-cursor: col-resize;
                        pointer-event(e) => { if (e.kind == PointerEventKind.down) { drag-start-x = self.absolute-position.x + self.mouse-x; drag-start-w = col-name-w; } }
                        moved => { col-name-w = clamp(drag-start-w + (self.absolute-position.x + self.mouse-x - drag-start-x), 40px, avail - col-status-w - col-done-w - col-down-w - 40px); }
                    }
                }

                // Status
                Text {
                    width: col-status-w;
                    text: tr-column-status;
                    color: #4a5870; font-size: 11px;
                    horizontal-alignment: center; vertical-alignment: center;
                }

                // Разделитель Status|Done
                Rectangle {
                    width: 9px; height: parent.height;
                    property <length> drag-start-x; property <length> drag-start-w;
                    Rectangle { width: 1px; height: parent.height; x: 4px; background: sep-sd.has-hover ? #3a5070 : #1e2a3a; }
                    sep-sd := TouchArea {
                        mouse-cursor: col-resize;
                        pointer-event(e) => { if (e.kind == PointerEventKind.down) { drag-start-x = self.absolute-position.x + self.mouse-x; drag-start-w = col-status-w; } }
                        moved => { col-status-w = clamp(drag-start-w + (self.absolute-position.x + self.mouse-x - drag-start-x), 40px, avail - col-name-w - col-done-w - col-down-w - 40px); }
                    }
                }

                // Done — сортировка
                Rectangle {
                    width: col-done-w;
                    hdr-done := TouchArea {
                        clicked => {
                            if (sort-col == "done") { sort-asc = !sort-asc; }
                            else { sort-col = "done"; sort-asc = true; }
                            sort-changed(sort-col, sort-asc);
                        }
                    }
                    Text {
                        text: tr-column-done + (sort-col == "done" ? (sort-asc ? " ↑" : " ↓") : "");
                        color: #4a5870; font-size: 11px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                // Разделитель Done|Down
                Rectangle {
                    width: 9px; height: parent.height;
                    property <length> drag-start-x; property <length> drag-start-w;
                    Rectangle { width: 1px; height: parent.height; x: 4px; background: sep-dd.has-hover ? #3a5070 : #1e2a3a; }
                    sep-dd := TouchArea {
                        mouse-cursor: col-resize;
                        pointer-event(e) => { if (e.kind == PointerEventKind.down) { drag-start-x = self.absolute-position.x + self.mouse-x; drag-start-w = col-done-w; } }
                        moved => { col-done-w = clamp(drag-start-w + (self.absolute-position.x + self.mouse-x - drag-start-x), 30px, avail - col-name-w - col-status-w - col-down-w - 40px); }
                    }
                }

                // Down — сортировка
                Rectangle {
                    width: col-down-w;
                    hdr-down := TouchArea {
                        clicked => {
                            if (sort-col == "down") { sort-asc = !sort-asc; }
                            else { sort-col = "down"; sort-asc = false; }
                            sort-changed(sort-col, sort-asc);
                        }
                    }
                    Text {
                        text: tr-column-down + (sort-col == "down" ? (sort-asc ? " ↑" : " ↓") : "");
                        color: #4a5870; font-size: 11px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                // Разделитель Down|Up
                Rectangle {
                    width: 9px; height: parent.height;
                    property <length> drag-start-x; property <length> drag-start-w;
                    Rectangle { width: 1px; height: parent.height; x: 4px; background: sep-du.has-hover ? #3a5070 : #1e2a3a; }
                    sep-du := TouchArea {
                        mouse-cursor: col-resize;
                        pointer-event(e) => { if (e.kind == PointerEventKind.down) { drag-start-x = self.absolute-position.x + self.mouse-x; drag-start-w = col-down-w; } }
                        moved => { col-down-w = clamp(drag-start-w + (self.absolute-position.x + self.mouse-x - drag-start-x), 40px, avail - col-name-w - col-status-w - col-done-w - 40px); }
                    }
                }

                // Up — сортировка
                Rectangle {
                    horizontal-stretch: 1;
                    hdr-up := TouchArea {
                        clicked => {
                            if (sort-col == "up") { sort-asc = !sort-asc; }
                            else { sort-col = "up"; sort-asc = false; }
                            sort-changed(sort-col, sort-asc);
                        }
                    }
                    Text {
                        text: tr-column-up + (sort-col == "up" ? (sort-asc ? " ↑" : " ↓") : "");
                        color: #4a5870; font-size: 11px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

            }
        }

        // ── Torrent list ──────────────────────────────────────────────────────
        ListView {
            vertical-stretch: 1;

            for item[idx] in torrents : TorrentRow {
                item: item;
                is-even: mod(idx, 2) == 0;
                is-selected: idx == selected-index;
                row-index: idx;
                col-name-w:   col-name-w;
                col-status-w: col-status-w;
                col-done-w:   col-done-w;
                col-down-w:   col-down-w;
                request-context-menu(id, tname, tdir, is-paused, pos-x, pos-y, idx) => {
                    selected-index = idx;
                    context-menu-visible = true;
                    context-menu-target-id = id;
                    context-menu-target-index = idx;
                    context-menu-torrent-name = tname;
                    context-menu-torrent-dir = tdir;
                    context-menu-target-paused = is-paused;
                    context-menu-x = pos-x;
                    context-menu-y = pos-y;
                }
            }
        }

        if torrents.length == 0 : Rectangle {
            vertical-stretch: 1;
            Text {
                text: connected ? "No torrents" : "Waiting for Transmission…";
                color: #263446; font-size: 15px;
                horizontal-alignment: center; vertical-alignment: center;
            }
        }
            } // end VerticalLayout main list
        } // end HorizontalLayout content

        // ── Status bar ────────────────────────────────────────────────────────
        Rectangle {
            height: 26px; background: #09101a;
            Rectangle { y: 0; x: 0; width: 100%; height: 1px; background: #182030; }

            HorizontalLayout {
                padding-left: 0px; padding-right: 10px;
                spacing: 0px;

                // ── IP + DHT/conn блок (200px — вровень с сайдбаром) ─────────
                Rectangle {
                    width: 200px;
                    background: ip-ta.has-hover || rpc-popup-visible ? #141e2e : transparent;
                    animate background { duration: 100ms; }
                    Rectangle { x: parent.width - 1px; width: 1px; height: parent.height; background: #182030; }

                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px; spacing: 6px;
                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            background: connected ? #2a9a50 : #8a3030;
                            y: (parent.height - self.height) / 2;
                        }
                        ip-text := Text {
                            text: rpc-url;
                            color: ip-ta.has-hover || rpc-popup-visible ? #90b8d8 : #4a6070;
                            font-size: 11px; vertical-alignment: center;
                            overflow: elide;
                            animate color { duration: 100ms; }
                        }
                    }
                    ip-ta := TouchArea {
                        clicked => { if (rpc-candidates.length > 1) { rpc-popup-visible = !rpc-popup-visible; } }
                    }
                }

                // ── DHT / conn — правее разделителя, левее StatsBar ──────────
                if connected: HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 8px;
                    Text {
                        text: tr-statusbar-dht + " " + stats.dht;
                        color: #3a5060; font-size: 11px; vertical-alignment: center;
                    }
                    Rectangle { width: 1px; height: 12px; background: #182030; y: (parent.height - self.height) / 2; }
                    Text {
                        text: stats.peers + " " + tr-statusbar-conn;
                        color: #3a5060; font-size: 11px; vertical-alignment: center;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                if connected : StatsBar { stats: stats; }
            }
        }

        // ── RPC popup ────────────────────────────────────────────────────────
        if rpc-popup-visible: Rectangle {
            width: 100%; height: 100%; z: 300;
            TouchArea { clicked => { rpc-popup-visible = false; } }
            Rectangle {
                x: 0px; y: parent.height - self.height - 26px;
                width: 220px;
                height: rpc-candidates.length * 28px + 8px;
                background: #1a2230; border-radius: 6px;
                border-width: 1px; border-color: #2a3a50;
                drop-shadow-blur: 12px; drop-shadow-color: #00000088;
                TouchArea { clicked => {} }
                VerticalLayout {
                    padding: 4px; spacing: 0px;
                    for url in rpc-candidates: Rectangle {
                        height: 28px; border-radius: 4px;
                        background: row-ta.has-hover ? #253040 : (url == rpc-url ? #1e3040 : transparent);
                        animate background { duration: 80ms; }
                        HorizontalLayout {
                            padding-left: 10px; padding-right: 10px; spacing: 6px;
                            Rectangle {
                                width: 6px; height: 6px; border-radius: 3px;
                                background: url == rpc-url ? #2a9a50 : #2a3a50;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: url; color: url == rpc-url ? #90b8d8 : #6a8090;
                                font-size: 11px; vertical-alignment: center; overflow: elide;
                            }
                        }
                        row-ta := TouchArea {
                            clicked => { rpc-popup-visible = false; if (url != rpc-url) { switch-rpc(url); } }
                        }
                    }
                }
            }
        }
    } // end VerticalLayout MainWindow

    // ── Context Menu (global) ────────────────────────────────────────────────
    if context-menu-visible: Rectangle {
        width: 100%; height: 100%;
        z: 150;
        TouchArea { clicked => { context-menu-visible = false; } }

        Rectangle {
            x: Math.max(8px, Math.min(context-menu-x * 1px, parent.width - self.width - 8px));
            y: Math.max(8px, Math.min((context-menu-y - 106) * 1px, parent.height - self.height - 8px));
            width: 240px; height: 212px;
            background: #1e2430;
            border-radius: 8px; border-width: 1px; border-color: #3a4560;
            TouchArea { clicked => {} }

            VerticalLayout {
                x: 4px; y: 4px;
                width: parent.width - 8px;
                spacing: 4px;

                Rectangle {
                    width: parent.width; height: 30px;
                    background: item-toggle.has-hover ? #2f3a50 : #2a3448;
                    border-radius: 4px;
                    item-toggle := TouchArea {
                        clicked => {
                            if (context-menu-target-paused) { start-torrent(context-menu-target-id); }
                            else                            { stop-torrent(context-menu-target-id); }
                            context-menu-visible = false;
                        }
                    }
                    Text {
                        text: (context-menu-target-paused ? "▶ " + tr-menu-start : "⏸ " + tr-menu-pause);
                        color: #c0d0e8; font-size: 13px;
                        x: 12px; y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: parent.width; height: 30px;
                    background: item-recheck.has-hover ? #2f3a50 : #2a3448;
                    border-radius: 4px;
                    item-recheck := TouchArea {
                        clicked => {
                            recheck-torrent(context-menu-target-id);
                            context-menu-visible = false;
                        }
                    }
                    Text {
                        text: "🔄 " + tr-menu-recheck;
                        color: #c0d0e8; font-size: 13px;
                        x: 12px; y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: parent.width; height: 30px;
                    background: item-folder.has-hover ? #2f3a50 : #2a3448;
                    border-radius: 4px;
                    item-folder := TouchArea {
                        clicked => {
                            open-folder(context-menu-torrent-dir);
                            context-menu-visible = false;
                        }
                    }
                    Text {
                        text: "📁 " + tr-menu-open-folder;
                        color: #c0d0e8; font-size: 13px;
                        x: 12px; y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: parent.width; height: 30px;
                    background: item-location.has-hover ? #2f3a50 : #2a3448;
                    border-radius: 4px;
                    item-location := TouchArea {
                        clicked => {
                            let last_path = get-last-location();
                            pick-context-menu-set-location(
                                context-menu-target-id,
                                context-menu-torrent-name,
                                last_path != "" ? last_path : context-menu-torrent-dir
                            );
                            context-menu-visible = false;
                        }
                    }
                    Text {
                        text: "📍 " + tr-menu-set-location;
                        color: #c0d0e8; font-size: 13px;
                        x: 12px; y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: parent.width; height: 30px;
                    background: item-remove.has-hover ? #3a2630 : #2a3448;
                    border-radius: 4px;
                    item-remove := TouchArea {
                        clicked => {
                            pending-id = context-menu-target-id;
                            pending-torrent-name = context-menu-torrent-name;
                            dialog-message = tr-dlg-remove-title + "\n" + tr-dlg-remove-subtitle;
                            pending-is-delete = true;
                            pending-delete-files = false;
                            dialog-visible = true;
                            context-menu-visible = false;
                        }
                    }
                    Text {
                        text: "✕ " + tr-menu-remove;
                        color: #d8bcc8; font-size: 13px;
                        x: 12px; y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: parent.width; height: 30px;
                    background: item-delete.has-hover ? #4a2020 : #2a3448;
                    border-radius: 4px;
                    item-delete := TouchArea {
                        clicked => {
                            pending-id = context-menu-target-id;
                            pending-torrent-name = context-menu-torrent-name;
                            dialog-message = tr-dlg-delete-title;
                            pending-is-delete = true;
                            pending-delete-files = true;
                            dialog-visible = true;
                            context-menu-visible = false;
                        }
                    }
                    Text {
                        text: "🗑 " + tr-menu-delete;
                        color: #f0b0b0; font-size: 13px;
                        x: 12px; y: (parent.height - self.height) / 2;
                    }
                }
            }
        }
    }

    // ── Set Location Dialog ──────────────────────────────────────────────────
    SetLocationDialog {
        width: 100%; height: 100%;
        visible-dialog: set-location-dialog-visible;
        torrent-name: set-location-torrent-name;
        path <=> set-location-path;
        do-move <=> set-location-do-move;
        pick-folder => {
            set-location-xdg-dialog(
                set-location-torrent-id,
                set-location-torrent-name,
                set-location-path,
                set-location-do-move
            );
            set-location-dialog-visible = false;
        }
        confirmed(p, mv) => {
            set-location-dialog-visible = false;
            set-location-cmd(set-location-torrent-id, p, mv);
        }
        cancelled => { set-location-dialog-visible = false; }
    }

    // ── Overlays ──────────────────────────────────────────────────────────────
    ConfirmDialog {
        width: 100%; height: 100%;
        message: dialog-message;
        torrent-name: pending-torrent-name;
        show-warning: pending-is-delete && pending-delete-files;
        visible-dialog: dialog-visible;
        tr-cancel: tr-dlg-cancel;
        tr-confirm: tr-dlg-confirm;
        tr-delete-warning: tr-dlg-delete-warning;
        tr-irreversible: tr-dlg-irreversible;
        confirmed => {
            dialog-visible = false;
            if (pending-is-delete)     { remove-torrent(pending-id, pending-delete-files); }
            else if (pending-id == -1) { start-all(); }
            else                       { stop-all(); }
        }
        cancelled => { dialog-visible = false; }
    }

    CloseDialog {
        width: 100%; height: 100%;
        visible-dialog: close-dialog-visible;
        minimize-to-tray => { close-dialog-visible = false; do-minimize-tray(); }
        quit-app         => { close-dialog-visible = false; do-quit(); }
        cancelled        => { close-dialog-visible = false; }
    }

    AddTorrentDialog {
        width: 100%; height: 100%;
        visible-dialog: add-dialog-visible;
        submitted-url(url) => { add-dialog-visible = false; add-torrent-url(url); }
        pick-file => { add-dialog-visible = false; pick-torrent-file(); }
        cancelled => { add-dialog-visible = false; }
    }

    CreateTorrentDialog {
        width: 100%; height: 100%;
        visible-dialog: create-dialog-visible;
        path-text <=> pending-create-path;
        submitted(path, trackers) => { create-dialog-visible = false; create-torrent(path, trackers); }
        pick-path => { pick-create-path(); }
        cancelled => { create-dialog-visible = false; pending-create-path = ""; }
    }

    MagnetDialog {
        width: 100%; height: 100%;
        visible-dialog: magnet-dialog-visible;
        magnet-uri <=> magnet-uri;
        submitted(uri) => { magnet-dialog-visible = false; magnet-submitted(uri); }
        cancelled => { magnet-dialog-visible = false; magnet-uri = ""; }
    }

    SettingsDialog {
        width: 100%; height: 100%;
        visible-dialog: settings-dialog-visible;
        selected-language <=> selected-language;
        language-changed(lang) => {
            settings-dialog-visible = false;
            language-changed(lang);
        }
        cancelled => { settings-dialog-visible = false; }
    }
}
